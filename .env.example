# Wix Blog REST API — configure only in Vercel or .env.local, never in client code.
WIX_API_KEY=
WIX_SITE_ID=

# Wix Custom App / Webhook verification.
WIX_APP_ID=
WIX_WEBHOOK_PUBLIC_KEY=

# Canonical public URL. Keep the production domain only after DNS cutover.
SITE_URL=https://www.dosadvocacia.com.br
